{
  "expo": {
    "name": "Ocean Sentinel",
    "slug": "ocean-sentinel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oceansentinel.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Ocean Sentinel needs camera access to identify fish species.",
        "NSPhotoLibraryUsageDescription": "Ocean Sentinel needs photo library access to identify fish from your gallery.",
        "NSLocationWhenInUseUsageDescription": "Ocean Sentinel uses your location to record where fish were spotted.",
        "NSLocationAlwaysUsageDescription": "Ocean Sentinel uses your location to record where fish were spotted."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.oceansentinel.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-media-library",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ]
    ],
    "extra": {
      "modelCacheVersion": "1"
    }
  }
}
