{
  "expo": {
    "name": "Ocean Sentinel",
    "slug": "ocean-sentinel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oceansentinel.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Ocean Sentinel needs camera access to identify fish species.",
        "NSPhotoLibraryUsageDescription": "Ocean Sentinel needs photo library access to identify fish from your gallery.",
        "NSLocationWhenInUseUsageDescription": "Ocean Sentinel uses your location to record where fish were spotted.",
        "NSLocationAlwaysUsageDescription": "Ocean Sentinel uses your location to record where fish were spotted.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.oceansentinel.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-media-library",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ]
    ],
    "extra": {
      "modelCacheVersion": "1",
      "eas": {
        "projectId": "5e87df30-69c5-47d9-810e-f694f8008198"
      }
    },
    "owner": "mafofoj"
  }
}
